          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/tactical-icons/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
