{
  "name": "bar-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "sync-unitpics": "node scripts/sync-unitpics.mjs",
    "audit-unitpics": "node scripts/audit-unitpics.mjs",
    "audit-unitpics:dist": "node scripts/audit-unitpics.mjs --dist",
    "audit-css": "node scripts/audit-css.mjs",
    "audit:bundle": "node scripts/audit-bundle.mjs",
    "consolidate-css": "node scripts/consolidate-css.mjs --write",
    "verify": "npm run lint && npm run test && npm run build && npm run audit:bundle && npm run audit-css && npm run audit-unitpics:dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "sharp": "^0.34.5",
    "three": "^0.185.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
